<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-primary fw-bold"><i class="bi bi-file-medical me-2"></i>Visit Record</h2>
                <div>
                    <button onclick="window.print()" class="btn btn-outline-dark me-2">
                        <i class="bi bi-printer"></i> Print Prescription
                    </button>
                    <a href="/patients/patient-profile/{{visit.patientId._id}}" class="btn btn-secondary">Back to Profile</a>
                </div>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 text-center">OFFICIAL MEDICAL RECORD</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr class="bg-light">
                                <th width="30%" class="ps-4">Patient Name</th>
                                <td class="ps-4 fw-bold text-uppercase">{{visit.patientId.name}}</td>
                            </tr>
                            <tr>
                                <th class="ps-4">Date of Visit</th>
                                <td class="ps-4">{{date}}</td>
                            </tr>
                            <tr class="bg-light">
                                <th class="ps-4">Attending Doctor</th>
                                <td class="ps-4">Dr. {{visit.doctorName}}</td>
                            </tr>
                            <tr>
                                <th class="ps-4">Diagnosis</th>
                                <td class="ps-4 text-danger fw-bold">{{visit.diagnosis}}</td>
                            </tr>
                            <tr class="bg-light">
                                <th class="ps-4">Prescribed Medicines</th>
                                <td class="ps-4" style="white-space: pre-line;">{{visit.medicines}}</td>
                            </tr>
                            <tr>
                                <th class="ps-4">Doctor's Advice</th>
                                <td class="ps-4 text-muted italic">{{visit.advice}}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white py-4 text-center">
                    <p class="small text-muted mb-0">This is a digital record generated by HMS Core.</p>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    @media print {
        .btn, nav, .card-footer { display: none !important; }
        .card { shadow: none !important; border: 1px solid #000 !important; }
        .container { margin-top: 0 !important; }
    }
</style>