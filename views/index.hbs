<div class="container mt-4">
    {{#if user}}
        <div class="alert alert-info border-0 shadow-sm d-flex justify-content-between align-items-center">
            <span>Welcome back, <strong>{{user.username}}</strong>! You are logged into the Clinical Portal.</span>
            <span class="badge bg-primary px-3 py-2">Staff Active</span>
        </div>
    {{else}}
        <div class="alert alert-warning border-0 shadow-sm">
            <strong>Notice:</strong> Please <a href="/auth/login" class="alert-link">Login</a> to access the Doctor Panel and Register Patients.
        </div>
    {{/if}}
    
    </div>  
<div class="text-center">
    <div class="p-5 mb-5 bg-white rounded-4 shadow-sm border">
        <h1 class="display-4 fw-bold text-dark">Hospital Dashboard</h1>
        <p class="lead text-muted">Efficiently manage patient records and clinical visits.</p>
        <hr class="my-4">

        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3 text-primary fs-1">👤</div>
                        <h3 class="h4">Register</h3>
                        <p class="text-muted">Onboard new patients into the system.</p>
                        <a href="/patients/add" class="btn btn-outline-primary w-100 mt-2">Add New</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3 text-success fs-1">📋</div>
                        <h3 class="h4">Records</h3>
                        <p class="text-muted">View and manage existing patient lists.</p>
                        <a href="/patients/list" class="btn btn-outline-success w-100 mt-2">View All</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm border-top border-primary border-4">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3 text-info fs-1">🩺</div>
                        <h3 class="h4 text-primary">Doctor Panel</h3>
                        <p class="text-muted">Prescribe medicines and log medical visits.</p>
                        <a href="/patients/doctor-panel" class="btn btn-primary w-100 mt-2">Open Panel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>